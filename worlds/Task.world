<?xml version="1.0" ?>
<sdf version="1.6">
  <world name="default">
  <max_step_size>0.001</max_step_size>
  <real_time_update_rate>1000</real_time_update_rate>
  <iters>50</iters>

    <scene>
      <sky>
        <clouds>
          <speed>12</speed>
        </clouds>
      </sky>
      <grid>false</grid>
      <origin_visual>false</origin_visual>
    </scene>

    <include>
      <uri>model://sun</uri>
    </include>
    <!-- fix -->
    <include>
      <uri>model://ground_plane</uri>
    </include>

