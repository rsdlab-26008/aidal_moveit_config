    <physics type="ode">
      <max_step_size>0.001</max_step_size>
      <real_time_factor>1</real_time_factor>
      <real_time_update_rate>1000.0</real_time_update_rate>
      <gravity>0 0 -9.8</gravity>

      <!-- fix -->
      <solver>
        <iters>500</iters>
        <sor>1.3</sor>
      </solver>
      <constraints>
        <cfm>0.0</cfm>
        <erp>0.2</erp>
      </constraints>

    </physics>

    <gui fullscreen='0'>
      <camera name='user_camera'>
        <!-- <pose>1.48967 -3.48202 4.55054 -0 0.516 2.00718</pose> -->
        <pose>11.503 8.665 9.109 0.0 0.582 -2.420</pose>
        <view_controller>orbit</view_controller>
      </camera>
    </gui>

    <!-- <include>
